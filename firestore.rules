rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if email is verified
    function isVerified() {
      return isAuth() && request.auth.token.email_verified == true;
    }

    // Helper: check if user owns the document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // User profiles
    match /users/{uid} {
      // Any authenticated user can read profiles (for leaderboards, game display)
      allow read: if isAuth();

      // Users can create their own profile (no verification required for initial signup)
      allow create: if isOwner(uid);

      // Users can only update their own profile
      allow update: if isOwner(uid)
        // If displayName is being changed, validate format
        && (request.resource.data.displayName == resource.data.displayName
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() >= 3
                && request.resource.data.displayName.size() <= 20));

      // Any authenticated user can update stats (local multiplayer: one device updates all players)
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats']);

      // Users can delete their own profile
      allow delete: if isOwner(uid);
    }

    // Games
    match /games/{gameId} {
      // Any authenticated user can read games
      allow read: if isAuth();

      // Verified users can create games
      allow create: if isVerified()
        && request.resource.data.playerIds is list
        && request.auth.uid in request.resource.data.playerIds
        && request.resource.data.startingScore in [301, 501, 701]
        && request.resource.data.legsToWin in [1, 3, 5];

      // Only players in the game can update it, must be verified
      allow update: if isVerified()
        && request.auth.uid in resource.data.playerIds;

      // Authenticated users can delete games (for reset)
      allow delete: if isAuth();
    }

    // Leaderboards (cached aggregations)
    match /leaderboards/{category} {
      // Anyone can read leaderboards
      allow read: if true;

      // Only verified users can update (client-side aggregation)
      allow write: if isVerified();
    }
  }
}
